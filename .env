# ════════════════════════════════════════════════════════════
# SUPABASE (Deixar vazio para fallback in-memory)
# ════════════════════════════════════════════════════════════
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ════════════════════════════════════════════════════════════
# AUTENTICAÇÃO
# ════════════════════════════════════════════════════════════
JWT_SECRET=pixel-perfect-pixels-dev-secret-key-minimum-32-chars-for-jwt
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# ════════════════════════════════════════════════════════════
# ENVIRONMENT
# ════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=4000

# ════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL for Docker)
# ════════════════════════════════════════════════════════════
POSTGRES_USER=erp_dev
POSTGRES_PASSWORD=erp_dev_password_2026
POSTGRES_DB=erp_database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ════════════════════════════════════════════════════════════
# SQUAD PORTS
# ════════════════════════════════════════════════════════════
SQUAD_PRODUCAO_PORT=3002
SQUAD_ESTOQUE_PORT=3003
SQUAD_CRM_PORT=3004
SQUAD_FINANCEIRO_PORT=3005
SQUAD_DASHBOARD_PORT=3006
SQUAD_QUALIDADE_PORT=3007
SQUAD_INTEGRADORES_PORT=3008

# ════════════════════════════════════════════════════════════
# MONITORING
# ════════════════════════════════════════════════════════════
PROMETHEUS_ENABLED=false
GRAFANA_ADMIN_PASSWORD=admin

# ════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════
LOG_LEVEL=debug
LOG_FORMAT=json
