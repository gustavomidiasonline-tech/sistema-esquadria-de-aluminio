# ════════════════════════════════════════════════════════════
# DOCKER / LOCAL POSTGRES (used by docker-compose)
# ════════════════════════════════════════════════════════════
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=erp_aluminio
POSTGRES_PORT=5432

# Squad host port overrides (optional — defaults shown)
PORT_PRODUCAO=3002
PORT_ESTOQUE=3003
PORT_CRM=3004
PORT_FINANCEIRO=3005
PORT_DASHBOARD=3006
PORT_QUALIDADE=3007
PORT_INTEGRADORES=3008
PORT_ORQUESTRADOR=4000

# ════════════════════════════════════════════════════════════
# SUPABASE DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ════════════════════════════════════════════════════════════
# AUTHENTICATION
# ════════════════════════════════════════════════════════════
JWT_SECRET=your-jwt-secret-key-minimum-32-characters
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# ════════════════════════════════════════════════════════════
# ENVIRONMENT
# ════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=4000

# ════════════════════════════════════════════════════════════
# MONITORING
# ════════════════════════════════════════════════════════════
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=admin

# ════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=json

# ════════════════════════════════════════════════════════════
# SMTP (Para notificações)
# ════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=erp@aluminio-vidracaria.com.br
