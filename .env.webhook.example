# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Configuração de Webhooks — Redes Sociais (Meta API)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Meta API — Access Token
# Obtenha em: https://developers.facebook.com/docs/graph-api/get-started
VITE_META_API_TOKEN=seu_access_token_aqui

# Meta API — Page ID (Facebook Page)
VITE_META_PAGE_ID=seu_page_id

# WhatsApp — Phone Number ID
# Obtenha em: https://developers.facebook.com/docs/whatsapp/cloud-api/
VITE_WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id

# Meta App — Credenciais de App
VITE_META_APP_ID=seu_app_id
VITE_META_APP_SECRET=seu_app_secret

# Webhook — URL pública do seu backend
# IMPORTANTE: Esta URL deve ser acessível da internet
# Exemplo: https://seu-dominio.com/api/webhooks/meta
VITE_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/meta

# Webhook — Verify Token (token aleatório para validação)
# Use um token aleatório forte (ex: openssl rand -hex 16)
# Pode ser qualquer string, use para validar requisições
VITE_WEBHOOK_VERIFY_TOKEN=seu_token_aleatorio_forte_aqui

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Instruções de Setup
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. Criar app Meta em: https://developers.facebook.com/apps
#
# 2. Obter tokens e IDs:
#    - App ID: Settings → Basic
#    - Access Token: Tools → Token Debugger
#    - Page ID: facebook.com/[seu-user]/pages
#    - Phone ID: WhatsApp Cloud API → Sender ID
#
# 3. Configurar Webhook no Meta:
#    - App → Products → WhatsApp → Configuration
#    - Subscription fields: messages, message_status_update
#    - Callback URL: https://seu-dominio.com/api/webhooks/meta
#    - Verify Token: seu_token_aleatorio_forte_aqui
#
# 4. Testar webhook:
#    curl -X POST https://seu-dominio.com/api/webhooks/meta \
#      -H "Content-Type: application/json" \
#      -d '{"entry": [{"messaging": [{"sender": {"id": "123"}, "message": {"text": "Teste"}}]}]}'
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
