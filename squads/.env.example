# ============================================================
# Squads ERP — Environment Variables
# ============================================================
# Copy this file to squads/.env (or set variables in the shell)
# before starting any squad server.
#
# The squads use dotenv from the project root, so you can also
# keep a single .env at the project root with these keys.
# ============================================================

# ------------------------------------------------------------
# Supabase — Required for persistent storage
# ------------------------------------------------------------
# Found at: Supabase Dashboard > Project Settings > API

# Your Supabase project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Service Role key — bypasses RLS (use ONLY on server-side/squads)
# NEVER expose this key in the browser or frontend code
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon/Public key — used when service role is not available
# (limited by RLS policies)
SUPABASE_ANON_KEY=eyJ...

# ------------------------------------------------------------
# Squad Ports (defaults shown — override as needed)
# ------------------------------------------------------------
PORT_ORQUESTRADOR=3001
PORT_PRODUCAO=3002
PORT_ESTOQUE=3003
PORT_CRM=3004
PORT_FINANCEIRO=3005
PORT_DASHBOARD=3006
PORT_QUALIDADE=3007
PORT_INTEGRADORES=3008

# ------------------------------------------------------------
# Node environment
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are absent,
# all squads fall back to in-memory storage automatically.
# No crash — graceful degradation is built into db-service.js.
#
# Migration to apply before first run:
#   supabase db push
# or apply manually:
#   supabase/migrations/20260317200000_squads_persistence_layer.sql
